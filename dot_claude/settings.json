    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "NODE_EXTRA_CA_CERTS": "/Users/craig.russell/.netskope-ca.pem",
    "XDG_RUNTIME_DIR": "/Users/craig.russell/xdg-runtime",
    "TMUX_ASSISTANT_RESURRECT_DIR": "/Users/craig.russell/xdg-runtime/tmux-assistant-resurrect"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Task",
      "Skill",
      "Agent",
      "NotebookEdit",
      "ToolSearch",
      "mcp__*"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(dd if=/dev/zero of=/dev/*)",
      "Bash(dd if=/dev/random of=/dev/*)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(parted *)",
      "Bash(nc -l *)",
      "Bash(netcat -l *)",
      "Bash(socat *)",
      "Bash(base64 -d | sh *)",
      "Bash(base64 -d | bash *)",
      "Bash(passwd *)",
      "Bash(nmap *)",
      "Bash(masscan *)",
      "Bash(xmrig *)",
      "Bash(monero *)",
      "Bash(bitcoin *)",
      "Bash(miner *)",
      "Bash(git push --force origin master *)",
      "Bash(git push --force origin main *)",
      "Bash(git push -f origin master *)",
      "Bash(git push -f origin main *)",
      "Bash(git push --force origin trunk *)",
      "Bash(git push -f origin trunk *)",
      "Bash(git reset --hard origin/master *)",
      "Bash(git reset --hard origin/main *)",
      "Bash(git reset --hard origin/trunk *)",
      "Bash(env | base64 *)",
      "Bash(printenv | base64 *)",
      "Bash(set | base64 *)",
      "Bash(bash -i >& /dev/tcp/*)",
      "Bash(sh -i >& /dev/tcp/*)",
      "Bash(exec < /dev/tcp/*)",
      "Bash(exec > /dev/tcp/*)",
      "Bash(exec 3<>/dev/tcp/*)",
      "Bash(systemctl mask *)",
      "Bash(systemctl disable *)",
      "Bash(curl *169.254.169.254*)",
      "Bash(wget *169.254.169.254*)",
      "Bash(curl *metadata.google.internal*)",
      "Bash(wget *metadata.google.internal*)",
      "Bash(history | grep -i password *)",
      "Bash(history | grep -i token *)",
      "Bash(history | grep -i secret *)",
      "Bash(grep -r password /etc/*)",
      "Bash(grep -r token /etc/*)",
      "Bash(grep -r secret /etc/*)",
      "Bash(find / -name id_rsa *)",
      "Bash(find / -name *.pem *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(halt *)",
      "Bash(poweroff *)",
      "Bash(init 0 *)",
      "Bash(init 6 *)",
      "Bash(rm /var/log/*)",
      "Bash(rm -rf /var/log/*)",
      "Bash(truncate -s 0 /var/log/*)",
      "Bash(insmod *)",
      "Bash(rmmod *)",
      "Bash(modprobe *)",
      "Bash(sysctl -w *)",
      "Bash(chmod -R 777 /*)",
      "Bash(chmod 777 /etc/*)",
      "Bash(chmod 777 /bin/*)",
      "Bash(chmod 777 /usr/*)",
      "Bash(find / -type f -delete *)",
      "Bash(find / -type d -delete *)",
      "Bash(rm -rf /home/*)",
      "Bash(rm -rf /var/*)",
      "Bash(rm -rf /opt/*)",
      "Bash(rm -rf /etc/*)",
      "Bash(rm -rf /bin/*)",
      "Bash(rm -rf /usr/*)",
      "Bash(gdb -p *)",
      "Bash(LD_PRELOAD=*)"
    ],
    "ask": [
      "Bash(kill *)",
      "Bash(pkill *)"
    ],
    "defaultMode": "plan"
  },
  "model": "claude-opus-4-7[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/craig.russell/.claude/scripts/enforce-worktree.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Hook input: $ARGUMENTS\n\nExtract tool_input.file_path. If the path contains any of: .env, .ssh/, id_rsa, id_ed25519, .pem, credentials, .netrc, .gnupg — output exactly the JSON {\"decision\":\"block\",\"reason\":\"<path> is a sensitive file — edit manually outside Claude Code\"} and stop. Otherwise produce no output.",
            "model": "claude-haiku-4-5-20251001",
            "timeout": 30,
            "statusMessage": "Checking for sensitive file..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/craig.russell/.claude/scripts/mcp-preflight.sh 2>/dev/null || true",
            "timeout": 15,
            "statusMessage": "Checking MCP server health..."
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/craig.russell/.config/tmux/plugins/tmux-assistant-resurrect/hooks/claude-session-track.sh'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/craig.russell/projects/claude-to-obsidian.py 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Syncing sessions to Obsidian..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/craig.russell/.claude/scripts/obsidian-log.sh 2>/dev/null || true",
            "timeout": 15,
            "statusMessage": "Logging compaction to Obsidian..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Hook input: $ARGUMENTS\n\nExtract tool_input.file_path. If it ends in .py and the file exists, invoke the `ruff` skill to format and lint-fix it. For any other file type, produce no output and stop immediately.",
            "model": "claude-haiku-4-5-20251001",
            "timeout": 60,
            "statusMessage": "Auto-formatting Python..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/craig.russell/.config/tmux/plugins/tmux-assistant-resurrect/hooks/claude-session-cleanup.sh'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
