#!/usr/bin/env python3
"""claude-attach <N> — resume the conversation pinned to slot N.

If slot N has no transcript yet (first attach), creates one with --session-id.
Otherwise resumes via --resume <uuid>.
"""
import json
import os
import sys
from pathlib import Path

SLOTS_FILE = Path.home() / ".claude-code" / "slots.json"
PROJECTS_DIR = Path.home() / ".claude" / "projects"


def main() -> None:
    if len(sys.argv) < 2:
        print("usage: claude-attach <N>", file=sys.stderr)
        sys.exit(2)

    key = sys.argv[1]
    if not SLOTS_FILE.exists():
        print(f"no slots file at {SLOTS_FILE}; run `claude-init`", file=sys.stderr)
        sys.exit(1)

    data = json.loads(SLOTS_FILE.read_text())
    slots = data.get("slots", {})
    if key not in slots:
        avail = ", ".join(
            sorted(slots.keys(), key=lambda x: int(x) if x.isdigit() else 1 << 30)
        ) or "(none)"
        print(f"slot '{key}' not registered. Available: {avail}", file=sys.stderr)
        sys.exit(1)

    slot = slots[key]
    sid = slot["uuid"]
    cwd = slot["cwd"]
    name = slot["name"]

    jsonl_exists = False
    if PROJECTS_DIR.exists():
        for _ in PROJECTS_DIR.glob(f"*/{sid}.jsonl"):
            jsonl_exists = True
            break

    try:
        os.chdir(cwd)
    except FileNotFoundError:
        print(f"cwd '{cwd}' missing; falling back to $HOME", file=sys.stderr)
        os.chdir(str(Path.home()))

    if jsonl_exists:
        os.execvp("claude", ["claude", "--resume", sid])
    else:
        os.execvp("claude", ["claude", "--session-id", sid, "-n", name])


if __name__ == "__main__":
    main()
