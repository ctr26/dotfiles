#!/usr/bin/env python3
"""claude-init [N] — pre-populate N stable slot UUIDs in ~/.claude-code/slots.json.

Each slot pins a UUID that `claude-attach <N>` will resume forever. Existing
slots are left untouched (idempotent).
"""
import json
import sys
import uuid
from pathlib import Path

SLOTS_FILE = Path.home() / ".claude-code" / "slots.json"
DEFAULT_CWD = str(Path.home())


def load_slots() -> dict:
    if not SLOTS_FILE.exists():
        return {"version": 1, "slots": {}}
    return json.loads(SLOTS_FILE.read_text())


def save_slots(data: dict) -> None:
    SLOTS_FILE.parent.mkdir(parents=True, exist_ok=True)
    tmp = SLOTS_FILE.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(data, indent=2) + "\n")
    tmp.replace(SLOTS_FILE)


def main() -> None:
    n = int(sys.argv[1]) if len(sys.argv) > 1 else 4
    if n < 1 or n > 64:
        print(f"N out of range: {n} (expected 1..64)", file=sys.stderr)
        sys.exit(2)

    data = load_slots()
    slots = data.setdefault("slots", {})

    created = 0
    for i in range(1, n + 1):
        key = str(i)
        if key not in slots:
            slots[key] = {
                "uuid": str(uuid.uuid4()),
                "name": f"slot-{i}",
                "cwd": DEFAULT_CWD,
            }
            created += 1

    save_slots(data)

    print(f"slots file: {SLOTS_FILE}")
    print(f"created {created} new slot(s); total {len(slots)} slot(s) registered")
    for k in sorted(slots.keys(), key=lambda x: int(x) if x.isdigit() else 1 << 30):
        s = slots[k]
        print(f"  slot {k:>3}: {s['uuid']}  ({s['name']})  cwd={s['cwd']}")


if __name__ == "__main__":
    main()
