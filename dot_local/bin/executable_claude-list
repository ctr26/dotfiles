#!/usr/bin/env python3
"""claude-list — show registered slots and their on-disk transcript state."""
import json
import sys
from datetime import datetime
from pathlib import Path

SLOTS_FILE = Path.home() / ".claude-code" / "slots.json"
PROJECTS_DIR = Path.home() / ".claude" / "projects"


def find_jsonl(uuid: str) -> Path | None:
    if not PROJECTS_DIR.exists():
        return None
    for p in PROJECTS_DIR.glob(f"*/{uuid}.jsonl"):
        return p
    return None


def main() -> None:
    if not SLOTS_FILE.exists():
        print(
            f"no slots file at {SLOTS_FILE}; run `claude-init` first",
            file=sys.stderr,
        )
        sys.exit(1)

    data = json.loads(SLOTS_FILE.read_text())
    slots = data.get("slots", {})
    if not slots:
        print("(no slots registered — try `claude-init 4`)")
        return

    header = f"{'slot':>4}  {'name':<14}  {'uuid':<36}  {'lines':>6}  {'mtime':<19}  cwd"
    print(header)
    print("-" * len(header))
    for k in sorted(slots.keys(), key=lambda x: int(x) if x.isdigit() else 1 << 30):
        s = slots[k]
        jsonl = find_jsonl(s["uuid"])
        if jsonl is not None:
            with jsonl.open() as f:
                lines = sum(1 for _ in f)
            mtime = datetime.fromtimestamp(jsonl.stat().st_mtime).strftime(
                "%Y-%m-%d %H:%M:%S"
            )
        else:
            lines = "-"
            mtime = "(empty)"
        print(
            f"{k:>4}  {s['name']:<14}  {s['uuid']:<36}  "
            f"{str(lines):>6}  {mtime:<19}  {s['cwd']}"
        )


if __name__ == "__main__":
    main()
