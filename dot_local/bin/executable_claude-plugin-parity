#!/usr/bin/env python3
"""claude-plugin-parity — compare Claude Code CLI plugins vs Cowork plugins.

CLI side:    ~/.claude/plugins/installed_plugins.json
Cowork side: <DARWIN_USER_TEMP_DIR>/claude-hostloop-plugins/<hash>/...
             (symlinks into rpm/plugin_<id>/ for marketplace plugins
              and skills-plugin/... for the anthropic-skills built-in)

Exit code: 0 on parity (no diff), 1 on any drift.
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

CLI_PLUGINS_FILE = Path.home() / ".claude" / "plugins" / "installed_plugins.json"


def _darwin_user_tempdir() -> Path | None:
    try:
        out = subprocess.check_output(
            ["getconf", "DARWIN_USER_TEMP_DIR"], text=True, stderr=subprocess.DEVNULL
        ).strip()
        return Path(out) if out else None
    except Exception:
        env = os.environ.get("TMPDIR")
        return Path(env) if env else None


def _hostloop_dir() -> Path | None:
    base = _darwin_user_tempdir()
    if not base:
        return None
    p = base / "claude-hostloop-plugins"
    return p if p.is_dir() else None


def cli_plugins() -> dict[str, str]:
    """Return {name@marketplace: version} for plugins installed by Claude Code."""
    if not CLI_PLUGINS_FILE.exists():
        return {}
    try:
        data = json.loads(CLI_PLUGINS_FILE.read_text())
    except json.JSONDecodeError as e:
        print(f"warn: could not parse {CLI_PLUGINS_FILE}: {e}", file=sys.stderr)
        return {}
    out: dict[str, str] = {}
    for key, instances in data.get("plugins", {}).items():
        if isinstance(instances, list) and instances:
            ver = instances[0].get("version") or "?"
        elif isinstance(instances, dict):
            ver = instances.get("version") or "?"
        else:
            ver = "?"
        out[key] = ver
    return out


def cowork_plugins() -> dict[str, str]:
    """Return {name@marketplace: version} for plugins managed by Cowork.

    Walks the hostloop cache: each entry is a symlink whose target is either
    an rpm/plugin_<id>/ dir (marketplace plugin) or the skills-plugin/... dir
    (anthropic built-in). Marketplace metadata comes from the sibling
    rpm/manifest.json when available; otherwise we fall back to <builtin>.
    """
    out: dict[str, str] = {}
    hostloop = _hostloop_dir()
    if not hostloop:
        return out

    # Cache rpm/manifest.json contents keyed by plugin_id.
    manifest_by_id: dict[str, dict] = {}
    seen_manifests: set[Path] = set()

    for entry in hostloop.iterdir():
        try:
            target = entry.resolve(strict=True)
        except (FileNotFoundError, RuntimeError):
            continue
        if not target.is_dir():
            continue

        # Skip per-session local .claude dirs — they aren't plugins.
        if target.name == ".claude":
            continue

        plugin_json = target / ".claude-plugin" / "plugin.json"
        if not plugin_json.is_file():
            continue

        # Pull marketplace info from rpm/manifest.json if this is an rpm plugin.
        manifest_path = target.parent / "manifest.json"
        if manifest_path.is_file() and manifest_path not in seen_manifests:
            try:
                m = json.loads(manifest_path.read_text())
                for p in m.get("plugins", []):
                    if "id" in p:
                        manifest_by_id[p["id"]] = p
                seen_manifests.add(manifest_path)
            except json.JSONDecodeError:
                pass

        try:
            pj = json.loads(plugin_json.read_text())
        except json.JSONDecodeError:
            continue

        name = pj.get("name") or target.name
        version = pj.get("version") or "?"

        # If we have manifest data for this rpm plugin id, prefer its marketplace name.
        marketplace = "<builtin>"
        plugin_id = target.name  # e.g. plugin_01QvsWzisi...
        meta = manifest_by_id.get(plugin_id)
        if meta:
            marketplace = meta.get("marketplaceName") or marketplace
            # Use manifest's updatedAt as a "version" surrogate when plugin.json has none.
            if version == "?" and meta.get("updatedAt"):
                version = meta["updatedAt"][:10]

        out[f"{name}@{marketplace}"] = version

    return out


def _short(key: str) -> str:
    return key.split("@", 1)[0]


def render(cli: dict[str, str], cw: dict[str, str], use_color: bool) -> bool:
    """Print parity report. Returns True on parity, False on drift."""
    R = "\033[31m" if use_color else ""
    G = "\033[32m" if use_color else ""
    Y = "\033[33m" if use_color else ""
    B = "\033[1m" if use_color else ""
    Z = "\033[0m" if use_color else ""

    cli_by_name = {_short(k): k for k in cli}
    cw_by_name = {_short(k): k for k in cw}

    common = sorted(set(cli_by_name) & set(cw_by_name))
    only_cli = sorted(set(cli_by_name) - set(cw_by_name))
    only_cw = sorted(set(cw_by_name) - set(cli_by_name))

    print(f"{B}Claude Code CLI plugins:{Z}  {len(cli)}")
    print(f"{B}Cowork plugins:{Z}           {len(cw)}")
    print()

    if common:
        print(f"{B}In both ({len(common)}):{Z}")
        for n in common:
            ck, wk = cli_by_name[n], cw_by_name[n]
            cv, wv = cli[ck], cw[wk]
            same_mp = ck.split("@", 1)[1] == wk.split("@", 1)[1]
            mp_note = "" if same_mp else f"  {Y}[different marketplace]{Z}"
            print(f"  {n:<32}  CLI={cv:<14} Cowork={wv}{mp_note}")
        print()

    if only_cli:
        print(f"{B}{R}Only in Claude Code CLI ({len(only_cli)}):{Z}")
        for n in only_cli:
            k = cli_by_name[n]
            print(f"  {k:<48}  v={cli[k]}")
        print()

    if only_cw:
        print(f"{B}{G}Only in Cowork ({len(only_cw)}):{Z}")
        for n in only_cw:
            k = cw_by_name[n]
            print(f"  {k:<48}  v={cw[k]}")
        print()

    parity = not (only_cli or only_cw)
    if parity:
        print(f"{G}✓ Plugin sets are in parity (by name).{Z}")
    else:
        print(f"{Y}⚠ Plugin sets differ.{Z}")
    return parity


def main() -> None:
    args = sys.argv[1:]
    as_json = "--json" in args
    no_color = "--no-color" in args or not sys.stdout.isatty()

    cli = cli_plugins()
    cw = cowork_plugins()

    if as_json:
        cli_by_name = {_short(k): k for k in cli}
        cw_by_name = {_short(k): k for k in cw}
        common = sorted(set(cli_by_name) & set(cw_by_name))
        only_cli = sorted(set(cli_by_name) - set(cw_by_name))
        only_cw = sorted(set(cw_by_name) - set(cli_by_name))
        report = {
            "cli": cli,
            "cowork": cw,
            "in_both": [
                {
                    "name": n,
                    "cli_key": cli_by_name[n],
                    "cli_version": cli[cli_by_name[n]],
                    "cowork_key": cw_by_name[n],
                    "cowork_version": cw[cw_by_name[n]],
                }
                for n in common
            ],
            "only_cli": [cli_by_name[n] for n in only_cli],
            "only_cowork": [cw_by_name[n] for n in only_cw],
            "parity": not (only_cli or only_cw),
        }
        print(json.dumps(report, indent=2))
        sys.exit(0 if report["parity"] else 1)

    parity = render(cli, cw, use_color=not no_color)
    sys.exit(0 if parity else 1)


if __name__ == "__main__":
    main()
