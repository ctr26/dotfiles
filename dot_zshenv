# Ensure essential system paths are always present (Arch/EndeavourOS + WSL)
# These MUST come first — without /usr/bin, nothing works on Arch
typeset -U PATH
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:$PATH"

# User scripts (chezmoi-managed) — claude-attach/list/init/new/kill etc.
# Must be in zshenv so SSH non-interactive sessions (e.g. \`ssh host claude-attach 1\`)
# can resolve them; zshrc is interactive-only.
export PATH="$HOME/.local/bin:$PATH"

[ -f "$HOME/.env" ] && source "$HOME/.env"
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Claude Code experimental features
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# Safety net: re-assert system paths at the end in case anything above clobbered them
export PATH="$PATH:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
