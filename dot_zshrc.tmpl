# >>> conda initialize >>>
# !! Contents within this block are managed by 'conda init' !!
__conda_setup="$('$HOME/miniconda3/bin/conda' 'shell.zsh' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]; then
        . "$HOME/miniconda3/etc/profile.d/conda.sh"
    else
        export PATH="$HOME/miniconda3/bin:$PATH"
        {{- if eq .chezmoi.os "darwin" }}
        export PATH="/opt/homebrew/Caskroom/miniconda/base/bin:$PATH"
        {{ end }}
    fi
fi
unset __conda_setup
# <<< conda initialize <<<

# OpenClaw Completion
[[ -f "$HOME/.openclaw/completions/openclaw.zsh" ]] && source "$HOME/.openclaw/completions/openclaw.zsh"
{{- if eq .chezmoi.os "darwin" }}
export PATH="/opt/homebrew/bin:$PATH"
{{- else }}
export PATH="/opt/brew/bin:$PATH"
{{- end }}

# Fix npm prefix and add local bin to PATH
unset NPM_CONFIG_PREFIX
export PATH="$HOME/.local/bin:$PATH"
# GITHUB_PERSONAL_ACCESS_TOKEN in ~/.env (sourced by .zshenv)
command -v fnm &>/dev/null && eval "$(fnm env --use-on-cd --shell zsh)"

# Modern CLI tool integrations (mise, direnv, zoxide, fzf)
command -v mise &>/dev/null && eval "$(mise activate zsh)"
command -v direnv &>/dev/null && eval "$(direnv hook zsh)"
command -v zoxide &>/dev/null && eval "$(zoxide init zsh)"
[ -f /opt/homebrew/opt/fzf/shell/key-bindings.zsh ] && source /opt/homebrew/opt/fzf/shell/key-bindings.zsh
[ -f /opt/homebrew/opt/fzf/shell/completion.zsh ] && source /opt/homebrew/opt/fzf/shell/completion.zsh

# Auto-switch gh account based on .gh-account file in project tree
_gh_auto_switch() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -f "$dir/.gh-account" ]]; then
      local want="$(< "$dir/.gh-account")"
      want="${want%$'\n'}"
      local current="$(gh auth status 2>&1 | grep 'Active account: true' -B1 | head -1 | awk '{print $NF}')"
      if [[ -n "$want" && "$want" != "$current" ]]; then
        gh auth switch --user "$want" 2>/dev/null
      fi
      return
    fi
    dir="${dir:h}"
  done
}
autoload -U add-zsh-hook
add-zsh-hook chpwd _gh_auto_switch
_gh_auto_switch  # run once at shell start

[[ -s {{ .chezmoi.homeDir }}/.cache/yay/autojump/pkg/autojump/etc/profile.d/autojump.sh ]] && source {{ .chezmoi.homeDir }}/.cache/yay/autojump/pkg/autojump/etc/profile.d/autojump.sh

autoload -U compinit && compinit -u

# =============================================================================
# 1Password — SSH agent + CLI integration
# =============================================================================
# Route SSH agent traffic through the 1Password desktop app.
# Requires: 1Password → Settings → Developer → "Use the SSH agent" enabled.
export SSH_AUTH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# 1Password CLI completions
if command -v op >/dev/null 2>&1; then
    eval "$(op completion zsh)"
    compdef _op op
fi

# Run a command with secrets injected from a 1Password .env template.
# Usage: oprun pnpm dev          (reads ./.env.tpl by default)
#        OPRUN_ENV_FILE=foo.tpl oprun python app.py
oprun() { op run --env-file="${OPRUN_ENV_FILE:-.env.tpl}" -- "$@"; }

# =============================================================================
# Claude Code <-> Cowork plugin parity
# =============================================================================
# Top-level `claude plugin ...` subcommands run outside any Claude Code session,
# so the in-session hook events (PreToolUse, PostToolUse, SessionStart, etc.)
# don't catch them. This wrapper intercepts the CLI, runs the command, and
# then prints a parity diff against the Cowork plugin set.
# Disable with: CLAUDE_PLUGIN_PARITY=0
claude() {
  if [[ "$1" == "plugin" || "$1" == "plugins" ]] && [[ "${CLAUDE_PLUGIN_PARITY:-1}" != "0" ]]; then
    command claude "$@"
    local rc=$?
    if [[ -x "$HOME/.local/bin/claude-plugin-parity" ]]; then
      print -P "%F{8}---%f %F{6}claude-plugin-parity%f"
      "$HOME/.local/bin/claude-plugin-parity" || true
    fi
    return $rc
  fi
  command claude "$@"
}

