# =============================================================================
# Global defaults
# =============================================================================
Host *
    AddKeysToAgent yes
    ForwardAgent yes
    ServerAliveInterval 60
    ServerAliveCountMax 3

# =============================================================================
# GitHub — ctr26 (work/OSS)
# =============================================================================
Host github-ctr26
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_rsa
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

# =============================================================================
# GitHub — craggles17 (personal)
# =============================================================================
Host github-craggles17
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_rsa
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

{{- if or (lookPath "sft") (stat "/usr/local/bin/sft") }}

# =============================================================================
# Work (ScaleFT/Okta ASA required)
# =============================================================================

Host slclogin2
    HostName slclogin2

Host hpc-job
    ProxyCommand ssh slclogin1 "nc \$(/cm/shared/apps/slurm/current/bin/squeue --me --name=tunnel --states=R -h -O NodeList) 2222"
    StrictHostKeyChecking no

Match exec "/usr/local/bin/sft resolve -q  %h"
    ProxyCommand /usr/local/bin/sft proxycommand %h
    UserKnownHostsFile {{ .chezmoi.homeDir }}/Library/Application Support/ScaleFT/proxycommand_known_hosts
{{- end }}

# =============================================================================
# Personal infrastructure
# =============================================================================
Host router
    HostName craggles.duckdns.org
    User admin
    Port 8008

Host proxmox
    HostName proxmox.
    User root
    ProxyJump router

Host narchie
    HostName narchie.
    User ctr26
    ProxyJump router

Host arch
    HostName arch.
    User craggles
    ProxyJump proxmox

# =============================================================================
# GCP — managed by: gcloud compute config-ssh (entries appended below)
# =============================================================================
{{- if stat (joinPath .chezmoi.homeDir ".ssh/google_compute_engine") }}

Host dev-vm.europe-west2-c.sixth-embassy-415210
    HostName 34.89.27.206
    IdentityFile {{ .chezmoi.homeDir }}/.ssh/google_compute_engine
    UserKnownHostsFile={{ .chezmoi.homeDir }}/.ssh/google_compute_known_hosts
    HostKeyAlias=compute.743109729887390176
    IdentitiesOnly=yes
    CheckHostIP=no
{{- end }}

