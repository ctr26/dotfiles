#!/bin/sh
# chezmoi:template
# Reinstalls global agent skills when the lockfile changes
# Hash: {{ include "dot_agents/dot_skill-lock.json" | sha256sum }}

set -e

if ! command -v npx >/dev/null 2>&1; then
  echo "npx not found, skipping skills install"
  exit 0
fi

LOCK_FILE="{{ .chezmoi.homeDir }}/.agents/.skill-lock.json"

if [ ! -f "$LOCK_FILE" ]; then
  echo "No skill-lock.json found, skipping"
  exit 0
fi

echo "Installing global agent skills from lockfile..."
npx -y skills@latest experimental_install

echo "Skills installed for: claude-code, gemini-cli, openclaw, codex"
